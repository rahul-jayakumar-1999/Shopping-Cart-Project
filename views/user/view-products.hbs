<section class="bg-light py-5 mb-5">
  <div class="container text-center">

    <h1 class="display-5 fw-bold">
      Welcome to Shopping Cart
    </h1>

    <p class="lead text-muted">
      Discover quality products at affordable prices.
    </p>

    <a href="#products" class="btn btn-success btn-lg">
      Shop Now
    </a>

  </div>
</section>

<section class="container mb-5" id="products">

  <h2 class="text-center fw-bold mb-4">
    Featured Products
  </h2>

  <div class="row g-4">

    {{#each products}}

      <div class="col-12 col-sm-6 col-lg-3">

        <div class="card h-100 shadow-sm border-0 product-card">

          <img
            src="/uploads/{{this.image}}"
            class="card-img-top"
            style="height:220px; object-fit:cover;"
          />

          <div class="card-body d-flex flex-column">

            <h5 class="card-title">
              {{this.name}}
            </h5>

            <p class="card-text text-muted flex-grow-1">
              {{this.description}}
            </p>

            <h5 class="text-success mb-3">
              {{currency this.price}}
            </h5>

            <button
              class="btn btn-primary w-100"
              onclick="addToCart('{{this._id}}')"
            >
              Add to Cart
            </button>

          </div>

        </div>

      </div>

    {{/each}}

  </div>

</section>

<footer class="bg-dark text-white py-4">

  <div class="container">

    <div class="row">

      <div class="col-md-6">
        <h5>Shopping Cart</h5>

        <p class="text-light">
          A simple online shopping website built with Node.js, Express, MongoDB
          and Handlebars.
        </p>
      </div>

      <div class="col-md-3">

        <h5>Quick Links</h5>

        <ul class="list-unstyled">

          <li><a href="/" class="text-decoration-none text-light">Home</a></li>

          <li><a
              href="/cart"
              class="text-decoration-none text-light"
            >Cart</a></li>

          {{#if user}}
            <li><a
                href="/orders"
                class="text-decoration-none text-light"
              >Orders</a></li>
          {{/if}}

        </ul>

      </div>

      <div class="col-md-3">

        <h5>Account</h5>

        {{#if user}}

          <a href="/logout" class="text-decoration-none text-light">
            Logout
          </a>

        {{else}}

          <a href="/login" class="text-decoration-none text-light">
            Login
          </a>

        {{/if}}

      </div>

    </div>

    <hr class="border-light" />

    <p class="text-center mb-0">
      © 2026 Shopping Cart. All Rights Reserved.
    </p>

  </div>

</footer>

<script src="/javascripts/countUpdate.js"></script>