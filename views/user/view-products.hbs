{{! Product Card grid }}
<section class="mt-4">
  <div class="container">
    <div class="row g-3">
      {{#each products}}
        <div class="col-md-3">
          <div class="card">
            <td><img src="../../uploads/{{this.image}}" alt="" /></td>
            <div class="card-body">
              <h5 class="card-title">{{this.name}}</h5>
              <p class="card-text">{{this.description}}</p>
              <p class="card-text">{{this.price}}</p>
              <a href="/add-to-cart/{{this._id}}" class="btn btn-primary">Add to cart</a>
            </div>
          </div>
        </div>
      {{/each}}
    </div>
  </div>
</section>