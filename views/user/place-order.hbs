<section class="container py-5">

  <h2 class="text-center fw-bold mb-5">
    Checkout
  </h2>

  <form class="row g-4" id="check-out-form">

    <!-- Delivery Details -->
    <div class="col-lg-7">

      <div class="card shadow-sm border-0 rounded-4">

        <div class="card-header bg-dark text-white">
          <h5 class="mb-0">Delivery Details</h5>
        </div>

        <div class="card-body">

          <div class="mb-3">
            <label class="form-label">Address</label>
            <input
              type="text"
              class="form-control"
              name="address"
              placeholder="Enter your address"
            />
          </div>

          <div class="mb-3">
            <label class="form-label">Pin Code</label>
            <input
              type="text"
              class="form-control"
              name="pincode"
              placeholder="Enter pin code"
            />
          </div>

          <div class="mb-3">
            <label class="form-label">Mobile Number</label>
            <input
              type="text"
              class="form-control"
              name="mobile"
              placeholder="Enter mobile number"
            />

            <input type="hidden" name="userID" value="{{user._id}}" />
          </div>

        </div>

      </div>

    </div>

    <!-- Order Summary -->
    <div class="col-lg-5">

      <div class="card shadow-sm border-0 rounded-4">

        <div class="card-header bg-success text-white">
          <h5 class="mb-0">Order Summary</h5>
        </div>

        <div class="card-body">

          <h3 class="text-success fw-bold">
            Total:
            {{currency total}}
          </h3>

          <hr />

          <h6 class="mb-3">Payment Method</h6>

          <div class="form-check border rounded p-3 mb-3">

            <input
              class="form-check-input"
              type="radio"
              name="paymentMethod"
              id="cod"
              value="COD"
              checked
            />

            <label class="form-check-label ms-2" for="cod">
              Cash on Delivery
            </label>

          </div>

          <div class="form-check border rounded p-3">

            <input
              class="form-check-input"
              type="radio"
              name="paymentMethod"
              id="online"
              value="ONLINE"
            />

            <label class="form-check-label ms-2" for="online">
              Online Payment
            </label>

          </div>

          <button type="submit" class="btn btn-success w-100 mt-4 py-2">
            Place Order
          </button>

        </div>

      </div>

    </div>

  </form>

</section>

<script src="/javascripts/form.submission.js"></script>