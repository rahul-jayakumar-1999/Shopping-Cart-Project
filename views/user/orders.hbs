<section class="container py-5">

  <h2 class="text-center fw-bold mb-5">
    My Orders
  </h2>

  {{#each orders}}

    <div class="card shadow-sm border-0 mb-4">

      <div class="card-body">

        <div class="row g-3 align-items-center">

          <!-- Order Details -->
          <div class="col-lg-8">

            <div class="row">

              <div class="col-md-4">
                <small class="text-muted">Order Date</small>
                <h6>{{formatDate this.orderDate}}</h6>
              </div>

              <div class="col-md-4">
                <small class="text-muted">Payment</small>
                <h6>{{this.paymentMethod}}</h6>
              </div>

              <div class="col-md-4">
                <small class="text-muted">Total</small>
                <h5 class="text-success">
                  {{currency this.totalAmount}}
                </h5>
              </div>

            </div>

            <hr />

            <h6 class="mb-2">
              Delivery Address
            </h6>

            <p class="text-muted mb-0">
              {{this.deliveryDetails.address}}<br />

              Pin Code :
              {{this.deliveryDetails.pincode}}<br />

              Mobile :
              {{this.deliveryDetails.mobile}}
            </p>

          </div>

          <!-- Status -->
          <div class="col-lg-4 text-lg-end">

            <span class="badge bg-success px-3 py-2 fs-6">
              {{this.status}}
            </span>

            <br /><br />

            <button
              class="btn btn-outline-primary"
              data-bs-toggle="collapse"
              data-bs-target="#order{{this._id}}"
            >
              View Products
            </button>

          </div>

        </div>

      </div>

      <!-- Products -->
      <div class="collapse" id="order{{this._id}}">

        <hr class="m-0" />

        <div class="card-body">

          {{#each this.products}}

            <div class="row align-items-center mb-3">

              <div class="col-2 col-md-1">

                <img
                  src="/uploads/{{this.orderProduct.image}}"
                  class="img-fluid rounded"
                />

              </div>

              <div class="col-5">

                <h6 class="mb-1">
                  {{this.orderProduct.name}}
                </h6>

              </div>

              <div class="col-2 text-center">

                Qty
                <br />

                <strong>{{this.quantity}}</strong>

              </div>

              <div class="col-3 text-end">

                <strong class="text-success">
                  {{currency this.orderProduct.price}}
                </strong>

              </div>

            </div>

            {{#unless @last}}
              <hr />
            {{/unless}}

          {{/each}}

        </div>

      </div>

    </div>

  {{/each}}

</section>