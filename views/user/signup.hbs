<section class="container">
  <h1 class="text-center mt-5">Sign Up</h1>
  <form class="w-25 mx-auto" method="post" action="/signup">
    <div class="mb-3">
      <label for="exampleInputName1" class="form-label">Email address</label>
      <input
        type="text"
        class="form-control"
        id="exampleInputName1"
        aria-describedby="textHelp"
        name="name"
      />
    </div>
    <div class="mb-3">
      <label for="exampleInputEmail1" class="form-label">Email address</label>
      <input
        type="email"
        class="form-control"
        id="exampleInputEmail1"
        aria-describedby="emailHelp"
        name="email"
      />
    </div>
    <div class="mb-3">
      <label class="form-label">Password</label>
      <input type="password" name="password" class="form-control" />
    </div>
    <button type="submit" class="btn btn-primary">Submit</button>
    <p class="text-center mt-5"><a class="link-opacity-100" href="/login">Already have an account.</a></p>
  </form>
</section>